# ============================================
# MacroActive - Consolidated Environment Config
# ============================================
# Copy this file to .env and update values

# ---- Backend API ----
NODE_ENV=development
PORT=3001
API_VERSION=v1
LOG_LEVEL=debug

# Database (PostgreSQL)
DATABASE_URL=postgresql://macroactive:macroactive@localhost:5432/streaks_badges
DATABASE_POOL_MIN=10
DATABASE_POOL_MAX=100
DATABASE_TIMEOUT=30000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# Queue (Bull)
QUEUE_REDIS_TLS=false
QUEUE_CONCURRENCY=10

# JWT Authentication
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=macroactive

# External Services
PUSH_SERVICE_URL=
PUSH_SERVICE_API_KEY=
ANALYTICS_API_KEY=

# Feature Flags
FEATURE_STREAKS_ENABLED=true
FEATURE_BADGES_ENABLED=true
FEATURE_LEADERBOARDS_ENABLED=true

# Timezone (for streak calculations)
DEFAULT_TIMEZONE=Pacific/Auckland

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3000

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
NEXT_PUBLIC_API_TIMEOUT=10000
NEXT_PUBLIC_APP_NAME=MacroActive
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STREAKS_ENABLED=true
NEXT_PUBLIC_BADGES_ENABLED=true
NEXT_PUBLIC_LEADERBOARDS_ENABLED=true
